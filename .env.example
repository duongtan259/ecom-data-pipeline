# Personal Data Pipeline — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── GCP ────────────────────────────────────────────────────────────────────────
# Your personal GCP project ID (e.g. my-personal-project-123)
GCP_PROJECT_ID=your-gcp-project-id

# Absolute path to your GCP service account JSON key
# The key needs BigQuery Data Editor + Job User roles
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# ── dbt ────────────────────────────────────────────────────────────────────────
# dbt target: dev or prod
DBT_TARGET=dev

# ── Airflow ────────────────────────────────────────────────────────────────────
AIRFLOW_UID=50000
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin
